{
  "name": "spriebsch/domain-event",
  "description": "Domain Events, Done Right.",
  "type": "library",
  "authors": [
    {
      "name": "Stefan Priebsch",
      "email": "stefan@priebsch.de",
      "homepage": "https://priebsch.de"
    }
  ],
  "license": "BSD-3-Clause",
  "require": {
    "php": ">=8.5",
    "crell/serde": "^1.6",
    "spriebsch/timestamp": "^1.1",
    "spriebsch/uuid": "^2.0",
    "spriebsch/filesystem": "^1.0"
  },
  "autoload": {
    "classmap": [
      "src",
      "tests"
    ]
  },
  "bin": [
    "bin/generate-topic-map.php"
  ],
  "scripts": {
    "clean": "rm -rf build",
    "test": [
      "if [ ! -f \"phpunit.phar\" ]; then cp /usr/local/bin/phpunit phpunit.phar; fi",
      "phpunit"
    ],
    "code-coverage": [
      "@putenv XDEBUG_MODE=coverage",
      "phpunit --coverage-html build/code-coverage"
    ],
    "path-coverage": [
      "@putenv XDEBUG_MODE=coverage",
      "phpunit --coverage-html build/code-coverage --path-coverage"
    ],
    "show-coverage": "gio open build/code-coverage/index.html"
  }
}
